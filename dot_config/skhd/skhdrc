# ============= basic ======================
# macbook keyboard
.device builtin { vendor: 0x05ac, product: 0x0343 }

.remap caps_lock [device builtin] : lctrl

lctrl - h | left
lctrl - j | down
lctrl - k | up
lctrl - l | right

# ============= yabai ======================
# 1. alt + hjkl 切换窗口
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east
# 2. alt + shift + hjkl 把当前窗口跟旁边窗口对调位置
alt + shift - h : yabai -m window --swap west
alt + shift - j : yabai -m window --swap south
alt + shift - k : yabai -m window --swap north
alt + shift - l : yabai -m window --swap east
# 3. alt + cmd + hjkl 动态拉伸窗口边缘
alt + cmd - h : yabai -m window --resize left:-20:0; yabai -m window --resize right:-20:0
alt + cmd - j : yabai -m window --resize bottom:0:20; yabai -m window --resize top:0:20
alt + cmd - k : yabai -m window --resize top:0:-20; yabai -m window --resize bottom:0:-20
alt + cmd - l : yabai -m window --resize right:20:0; yabai -m window --resize left:20:0
# 4. 窗口状态切换
# 一键让当前窗口全盘最大化
alt - f : yabai -m window --toggle zoom-parent
# 一键让当前窗口脱离平铺
alt - e : yabai -m window --toggle float --toggle border
# 自动平衡当前屏幕收窗口大小
alt - r : yabai -m space --balance
# 5. 夸桌面快速穿梭
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9
alt - 0 : yabai -m space --focus 10
# 6. 一键重启
alt + shift - r : yabai --restart-service

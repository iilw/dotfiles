#!/usr/bin/env bash

# 基础 yabai 配置
# 文档: https://github.com/koekeishiya/yabai/wiki

# mbp屏幕uuid
# yabai -m query --displays
MBP_UUID="37D8832A-2D66-02CA-B9F7-8F30A301B230"

# ======================== 全局设置 ========================

# 默认布局: bsp 自动平铺；需要临时浮动时可用 skhd 绑定切换
# 可选: bsp | stack | float
yabai -m config layout bsp
# 新窗口默认放在当前窗口右侧/下方
yabai -m config window_placement second_child
# 新窗口分割比例
yabai -m config split_ratio 0.50
# 自动平衡窗口大小：off 更符合手动调整习惯；想自动均分可改为 on
yabai -m config auto_balance off
# 窗口间距与屏幕边距
yabai -m config window_gap 10
# 如果有sketchybar下面脚本适配
yabai -m config top_padding 48
yabai -m config bottom_padding 12
yabai -m config left_padding 12
yabai -m config right_padding 12
# 关闭 yabai 自带透明度/阴影，减少视觉干扰
yabai -m config window_opacity off
yabai -m config window_shadow off
# 鼠标辅助：按住 fn + 鼠标左键拖动窗口，fn + 右键调整窗口大小
yabai -m config mouse_modifier fn
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_follows_focus off
yabai -m config focus_follows_mouse off


# MBP屏幕设置18
if command -v sketchybar >/dev/null 2>&1; then
  mbp_spaces=$(yabai -m query --displays | awk -v uuid="$MBP_UUID" '
    BEGIN { RS="}"; FS="," }
    $0 ~ uuid {
      # 在匹配到 UUID 的大括号块中，寻找 "spaces":[...] 这一行
      if (match($0, /"spaces":\[[0-9, ]+\]/)) {
        spaces_part = substr($0, RSTART, RLENGTH)
        # 去掉 JSON 的 [ ] 符号以及 "spaces": 前缀
        gsub(/["spaces":\[\]]/, "", spaces_part)
        # 替换逗号为空格，输出干净的数字列表，例如 "5 6"
        gsub(/,/, " ", spaces_part)
        print spaces_part
      }
    }
  ')

  if [ -n "$mbp_spaces" ]; then
    for space in $mbp_spaces; do
      yabai -m config --space "$space" top_padding 18 &
    done
    wait
  fi
fi

# 让所有窗口保持 normal 层级，避免部分窗口异常压住其它窗口
# 参考: https://github.com/koekeishiya/yabai/issues/1929
yabai -m rule --add app=".*" sub-layer=normal

# ======================== Space 标签 ========================
# 给常用桌面命名，方便规则和快捷键按名字跳转
yabai -m space 1 --label Projects
yabai -m space 2 --label Dotfiles
yabai -m space 3 --label Common --layout float
yabai -m space 4 --label Youtube
yabai -m space 5 --label Web
yabai -m space 6 --label Chat --layout float

# ======================== 窗口规则 ========================

yabai -m rule --add app="System Settings" manage=off           
yabai -m rule --add app="System Preferences" manage=off           
yabai -m rule --add app="Activity Monitor" manage=off           
yabai -m rule --add app="Notes" manage=off           
yabai -m rule --add app="Stickies" manage=off           
yabai -m rule --add app="Finder" manage=off           
yabai -m rule --add app="VibeStoreClient" manage=off           
yabai -m rule --add app="Alfred Preferences" manage=off           
yabai -m rule --add app="Music" manage=off           

yabai -m rule --add app="^(Preferences|Settings|About|Alfred).*$" manage=off


# 常用 App 分配到指定 Space；不需要可以删掉或改成自己的 App 名称
yabai -m rule --add app="^(kitty)$" space="Projects"
yabai -m rule --add app="^(Ghostty)$" space="Dotfiles"
yabai -m rule --add app="^(Google Chrome|Safari|Beave Browser)$" space="Web"
yabai -m rule --add app="^(WeChat|QQ|Telegram})$" space="Chat"

yabai -m rule --apply

# ======================== Signals ========================

# 如果安装了 borders，并且存在边框颜色脚本，则在切换焦点/应用/桌面时刷新边框颜色
border_script="${HOME}/.config/yabai/update_border_color.sh"
if command -v borders >/dev/null 2>&1 && [ -f "$border_script" ]; then
  yabai -m signal --add event=window_focused action="bash '$border_script'"
  yabai -m signal --add event=front_app_switched action="bash '$border_script'"
  yabai -m signal --add event=space_changed action="bash '$border_script'"
  bash "$border_script"
fi

# ======================== 启动提示 ========================

echo "yabai config loaded"
